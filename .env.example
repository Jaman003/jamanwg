# HTTP
JAMANWG_HOST=127.0.0.1
JAMANWG_PORT=8787

# Admin login. Change both before using on a server.
JAMANWG_ADMIN_USER=admin
JAMANWG_ADMIN_PASSWORD=change-me-now
JAMANWG_SESSION_SECRET=replace-with-64-random-hex-chars

# Bearer token for your website/backend integration.
JAMANWG_API_TOKEN=replace-with-api-token

# Optional separate Bearer token for Prometheus/Grafana scraping.
# If empty, /metrics accepts JAMANWG_API_TOKEN.
JAMANWG_METRICS_TOKEN=

# Storage
JAMANWG_DATA_DIR=./data

# AmneziaWG
JAMANWG_INTERFACE=awg0
JAMANWG_ADDRESS=10.66.64.1/22
JAMANWG_LISTEN_PORT=51820
JAMANWG_ENDPOINT=vpn.example.com:51820
JAMANWG_DNS=1.1.1.1
JAMANWG_ALLOWED_IPS=0.0.0.0/0
JAMANWG_MTU=1420
JAMANWG_CONFIG_PATH=/etc/amnezia/amneziawg/awg0.conf

# apply modes: auto, mock, config, live, both
# auto = mock when awg is unavailable, both when awg exists.
JAMANWG_APPLY_MODE=auto

# AmneziaWG obfuscation parameters.
JAMANWG_JC=4
JAMANWG_JMIN=8
JAMANWG_JMAX=80
JAMANWG_S1=30
JAMANWG_S2=80
JAMANWG_H1=123456789
JAMANWG_H2=234567891
JAMANWG_H3=345678912
JAMANWG_H4=456789123

# Optional firewall hooks in the generated server config.
# JAMANWG_POST_UP=iptables -A FORWARD -i awg0 -j ACCEPT
# JAMANWG_POST_DOWN=iptables -D FORWARD -i awg0 -j ACCEPT
